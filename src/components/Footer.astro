<style>
  footer {
    border-top: 0.5px solid var(--color-border);
    background: var(--color-bg);
    padding: 40px 28px 48px;
    margin-top: 64px;
  }
  .footer-inner {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }
  .footer-logo {
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 14px;
    letter-spacing: -0.4px;
  }
  .footer-logo span { color: var(--color-green-mid); }
  .footer-links {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12px 20px;
  margin-bottom: 20px;
  padding: 0 16px;
}
  .footer-links a {
    font-size: 13px;
    color: var(--color-muted);
    text-decoration: none;
  }
  .footer-links a:hover { color: var(--color-green); }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-bottom: 20px;
  }
  .social-links a {
    color: var(--color-hint);
    text-decoration: none;
    transition: color 0.15s;
  }
  .social-links a:hover { color: var(--color-green); }
  .footer-copy {
    font-size: 12px;
    color: var(--color-hint);
    margin-bottom: 10px;
  }
  .footer-disc {
    font-size: 11px;
    color: #B4B2A9;
    line-height: 1.7;
    max-width: 580px;
    margin: 0 auto;
  }
  @media (max-width: 480px) {
  .footer-links {
    gap: 10px 16px;
  }
  .footer-links a {
    font-size: 12px;
  }
}
</style>
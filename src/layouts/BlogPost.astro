---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, rctSources, readTime, category } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>

      <div class="article-header">
        <div class="evidence-tag">Evidence-based · No fluff</div>
        {category && <div class="category-tag">{category}</div>}
        <h1>{title}</h1>
        <div class="article-meta">
          {author && <span><strong>{author}</strong></span>}
          <span><FormattedDate date={pubDate} /></span>
          {readTime && <span>{readTime} read</span>}
          {rctSources && <span><strong>{rctSources} RCT sources</strong></span>}
          {updatedDate && <span>Updated: <FormattedDate date={updatedDate} /></span>}
        </div>
      </div>

      {heroImage && (
        <div class="hero-image">
          <Image width={1020} height={400} src={heroImage} alt={title} />
        </div>
      )}

      <div class="prose">
        <slot />
      </div>

    </main>
    <Footer />
  </body>
</html>

<style>
  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 40px 80px;
  }

  .article-header {
    padding: 48px 0 32px;
    border-bottom: 0.5px solid var(--color-border);
    margin-bottom: 36px;
  }

  .evidence-tag {
    display: inline-block;
    background: var(--color-green-light);
    color: var(--color-green);
    font-size: 10px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .category-tag {
    display: inline-block;
    background: var(--color-surface);
    color: var(--color-muted);
    font-size: 10px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 12px;
    margin-left: 6px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  h1 {
    font-family: 'Poppins', sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.5px;
    margin-bottom: 18px;
    color: var(--color-text);
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-size: 13px;
    color: var(--color-hint);
  }

  .article-meta strong {
    color: var(--color-green);
  }

  .hero-image {
    margin-bottom: 40px;
    border-radius: 12px;
    overflow: hidden;
  }

  .hero-image img {
  width: 100%;
  height: 360px;
  object-fit: cover;
  display: block;
}

@media (max-width: 640px) {
  .hero-image img {
    height: 220px;
  }

  main {
    padding: 0 20px 60px;
  }

  h1 {
    font-size: 24px;
  }

  .article-header {
    padding: 32px 0 24px;
  }
}

  /* PROSE STYLES */
.prose {
  font-size: 17.5px;
  line-height: 2;
  color: var(--color-text);
  max-width: 720px;
  margin: 0 auto;
}

.prose p {
  margin-bottom: 32px !important;
  margin-top: 0 !important;
}

.prose h2 {
  font-family: 'Poppins', sans-serif;
  font-size: 22px;
  font-weight: 700;
  letter-spacing: -0.4px;
  margin-top: 72px !important;
  margin-bottom: 24px !important;
  color: var(--color-text);
}

.prose h3 {
  font-family: 'Poppins', sans-serif;
  font-size: 18px;
  font-weight: 600;
  margin-top: 52px !important;
  margin-bottom: 18px !important;
  color: var(--color-text);
}

.prose ul, .prose ol {
  padding-left: 24px;
  margin-top: 8px !important;
  margin-bottom: 36px !important;
}

.prose li {
  margin-bottom: 12px !important;
  line-height: 1.8;
}

  .prose strong {
    font-weight: 600;
    color: var(--color-text);
  }

  .prose a {
    color: var(--color-green);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose blockquote {
    border-left: 3px solid var(--color-green-mid);
    padding: 14px 20px;
    margin: 36px 0;
    background: var(--color-green-light);
    border-radius: 0 8px 8px 0;
    font-size: 15px;
    color: var(--color-muted);
  }

  .prose hr {
    border: none;
    border-top: 0.5px solid var(--color-border);
    margin: 56px 0 48px;
  }

  /* Botões afiliados — espaço antes e depois */
  .prose a[style*="background:#3B6D11"],
  .prose a[style*="background: #3B6D11"] {
    display: inline-block;
    margin-top: 16px;
    margin-bottom: 40px;
  }

  /* Tabelas */
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 8px 0 40px;
    font-size: 13px;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .prose th {
    background: var(--color-surface);
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    font-size: 13px;
    color: var(--color-muted);
    border-bottom: 1px solid var(--color-border);
  }

  .prose td {
    padding: 10px 14px;
    border-bottom: 0.5px solid var(--color-border);
    vertical-align: top;
  }

  .prose tr:last-child td {
    border-bottom: none;
  }

  /* References section — só afeta o div inline, não h2 */
  .prose h2:last-of-type {
    margin-top: 16px;
    margin-bottom: 16px;
  }

  .prose p:has(a[href*="pubmed"]),
  .prose p:has(a[href*="nih"]) {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: 10px;
  }

  .prose code {
    background: var(--color-surface);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 14px;
  }

  /* Espaço entre divs inline e texto */
  .prose div[style] {
    margin-top: 36px;
    margin-bottom: 36px;
  }

  /* Espaço após parágrafos com links internos */
  .prose p + p {
    margin-top: 4px;
  }

  /* Primeiro parágrafo após h2 sem margin extra */
  .prose h2 + p {
    margin-top: 0;
  }

  /* Espaço entre hr e o que vem depois */
  .prose hr + * {
    margin-top: 48px;
  }

  /* FAQ perguntas em bold */
  .prose p > strong:first-child {
    display: block;
    margin-top: 40px;
    margin-bottom: 10px;
    font-size: 16px;
  }

/* ===== NOVAS REGRAS PARA MELHORAR ESPAÇAMENTO ===== */

/* Espaçamento antes do FAQ e seções importantes */
.prose h2:has(+ p > strong:first-child) {
  margin-bottom: 24px;
}

/* Melhorar espaçamento da tabela */
.prose table {
  margin: 32px 0 48px !important;
  border-collapse: separate;
  border-spacing: 0;
  background: var(--color-surface);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.03);
}

.prose th {
  background: var(--color-green-light);
  color: var(--color-green);
  font-weight: 600;
  padding: 16px 20px;
  border-bottom: 1px solid var(--color-border);
}

.prose td {
  padding: 16px 20px;
  border-bottom: 1px solid var(--color-border);
  background: white;
}

.prose tr:last-child td {
  border-bottom: none;
}

/* Melhorar FAQ (perguntas em bold) */
.prose p > strong:first-child {
  display: block;
  margin-top: 48px !important;
  margin-bottom: 16px !important;
  font-size: 18px;
  color: var(--color-text);
  border-bottom: 1px solid var(--color-border);
  padding-bottom: 8px;
}

/* Espaçamento para as respostas do FAQ */
.prose p:has(> strong:first-child) + p {
  margin-top: 8px;
  margin-bottom: 24px;
  padding-left: 4px;
}

/* Melhorar divs com borda verde (Key insights) */
.prose div[style*="background: #EAF3DE"] {
  margin: 48px 0 !important;
  padding: 24px 28px !important;
  border-left-width: 4px !important;
}

/* Melhorar seção de referências */
.prose div[style*="display: flex; flex-direction: column; gap: 15px;"] {
  margin-top: 32px !important;
  margin-bottom: 60px !important;
  background: var(--color-surface);
  padding: 24px 28px;
  border-radius: 16px;
}

.prose div[style*="display: flex; flex-direction: column; gap: 15px;"] a {
  color: var(--color-green);
  text-decoration: none;
  font-weight: 500;
  margin-left: 6px;
}

.prose div[style*="display: flex; flex-direction: column; gap: 15px;"] a:hover {
  text-decoration: underline;
}

/* Espaçamento entre os itens das referências */
.prose div[style*="display: flex; flex-direction: column; gap: 15px;"] > div {
  margin-bottom: 0 !important;
}

/* Título "References" */
.prose div[style*="margin-top: 40px; margin-bottom: 20px;"] {
  margin-top: 60px !important;
  margin-bottom: 24px !important;
  letter-spacing: 1.5px;
}

</style>
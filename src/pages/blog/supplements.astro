---
import CookieBanner from '../../components/CookieBanner.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => p.data.category === 'Supplements')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Supplementation — LongevityStack"
      description="Evidence-based analysis of supplements that actually work — and honest discussion of what the research doesn't yet support."
    />
  </head>
  <body>
    <Header />
    <main>

      <div class="category-header">
        <div class="category-tag">Supplementation</div>
        <h1>Supplements</h1>
        <p>Evidence-based analysis of supplements that actually work — and honest discussion of what the research doesn't yet support.</p>
      </div>

      <div class="articles-grid">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="article-card">
            <div class="card-top">
              <div class="article-category">{post.data.category}</div>
              <div class="article-meta">
                {post.data.readTime && <span>{post.data.readTime} read</span>}
                {post.data.rctSources && <span>{post.data.rctSources} RCT sources</span>}
              </div>
            </div>
            <div class="article-title">{post.data.title}</div>
            <div class="article-excerpt">{post.data.excerpt || post.data.description}</div>
            <div class="article-arrow">Read the full analysis →</div>
          </a>
        ))}
      </div>

      <div class="second-cta">
        <span>Not sure where to start?</span>
        <a href="/start-here" class="cta">Start with the fundamentals →</a>
      </div>

    </main>
    <CookieBanner />
    <Footer />
  </body>
</html>

<style>
  main { max-width: 900px; margin: 0 auto; padding: 0 28px 80px; }

  .category-header {
    padding: 56px 0 40px;
    border-bottom: 0.5px solid var(--color-border);
    margin-bottom: 40px;
    max-width: 640px;
  }

  .category-tag {
    display: inline-block;
    background: var(--color-amber-light);
    color: var(--color-amber);
    font-size: 10px;
    font-weight: 600;
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 16px;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  h1 {
    font-family: 'Poppins', sans-serif;
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 14px;
    color: var(--color-text);
  }

  .category-header p {
    font-size: 15px;
    color: var(--color-muted);
    line-height: 1.75;
  }

  .articles-grid { display: flex; flex-direction: column; gap: 0; margin-bottom: 48px; }
  .article-card { display: flex; flex-direction: column; gap: 8px; padding: 24px 20px; border-bottom: 0.5px solid var(--color-border); text-decoration: none; border-radius: 8px; transition: background 0.15s; }
  .article-card:first-child { border-top: none; }
  .article-card:hover { background: var(--color-surface); }
  .card-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
  .article-category { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--color-green); }
  .article-meta { font-size: 11px; color: var(--color-hint); display: flex; gap: 10px; }
  .article-title { font-family: 'Poppins', sans-serif; font-size: 16px; font-weight: 600; color: var(--color-text); line-height: 1.4; }
  .article-excerpt { font-size: 13px; color: var(--color-muted); line-height: 1.65; max-width: 640px; }
  .article-arrow { font-size: 12px; color: var(--color-green); font-weight: 500; margin-top: 4px; }

  .second-cta { display: flex; align-items: center; justify-content: space-between; background: var(--color-surface); border-radius: 12px; padding: 20px 24px; margin-top: 16px; flex-wrap: wrap; gap: 16px; }
  .second-cta span { font-size: 15px; color: var(--color-muted); font-weight: 500; }
  .cta { display: inline-flex; align-items: center; background: var(--color-green); color: #EAF3DE; font-size: 13px; font-weight: 500; padding: 10px 22px; border-radius: 8px; text-decoration: none; }

  @media(max-width: 640px) {
    .card-top { flex-direction: column; align-items: flex-start; }
    .second-cta { flex-direction: column; }
  }
  .category-header p {
  font-size: 15px;
  color: var(--color-muted);
  line-height: 1.75;
  margin-top: 12px;
}
</style>